# S2 API key (optional — 없으면 rate limit 적용)
S2_API_KEY=

# 수집 범위 — YYYY 또는 YYYY-MM-DD (기본: 2020 ~ 오늘)
# YEAR_FROM=2024-01-15
# YEAR_TO=2026

# 배치 윈도우 (일, 0=전체). 예: 30 → 1회 실행에 30일치만 수집
# INGEST_WINDOW_DAYS=30

# 스케줄링 (cron이 interval보다 우선, 둘 다 없으면 1회 실행)
# INGEST_CRON=0 * * * *
# INGEST_INTERVAL=3600

# 재시도 횟수 (S2, PDF, SPECTER2, ES 공통)
# MAX_RETRIES=3

# 타임아웃 (초)
# S2_TIMEOUT=30
# SPECTER_TIMEOUT=120
# PDF_TIMEOUT=60
# ES_TIMEOUT=60

# Docker 볼륨 경로 (호스트 디렉토리)
# DATA_DIR=./data
# ES_DATA_DIR=es_data

# 로그 레벨
LOG_LEVEL=INFO

# 아래는 docker-compose에서 자동 설정되므로 보통 수정 불필요.
# 로컬 개발 시 (Docker 밖에서) 필요하면 주석 해제.
# ES_HOST=http://localhost:9200
# SPECTER_URL=http://localhost:8000
